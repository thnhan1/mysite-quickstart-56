<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:designPath="/etc/designs/default"
        cq:template="/libs/cq/workflow/templates/model"
        jcr:description="Workflow for reviewing and approving news articles. Journalist submits, reviewer approves or rejects."
        jcr:primaryType="cq:PageContent"
        jcr:title="Article Review and Approval"
        sling:resourceType="cq/workflow/components/pages/model"
        transient="{Boolean}false">
        <flow
            jcr:primaryType="nt:unstructured"
            sling:resourceType="cq/workflow/components/model/flow">
            <node0
                jcr:primaryType="nt:unstructured"
                jcr:title="Start"
                sling:resourceType="cq/workflow/components/model/start"
                type="START">
                <transitions jcr:primaryType="nt:unstructured">
                    <node0_x0023_node1
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="cq/workflow/components/model/transition"
                        to="node1"/>
                </transitions>
            </node0>
            <node1
                jcr:primaryType="nt:unstructured"
                jcr:description="Validates that the article has required fields (title, description)"
                jcr:title="Validate Article"
                sling:resourceType="cq/workflow/components/model/process"
                PROCESS="com.mysite.core.workflow.ValidateArticleStep"
                PROCESS_AUTO_ADVANCE="{Boolean}true"
                type="PROCESS">
                <transitions jcr:primaryType="nt:unstructured">
                    <node1_x0023_node2
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="cq/workflow/components/model/transition"
                        to="node2"/>
                </transitions>
            </node1>
            <node2
                jcr:primaryType="nt:unstructured"
                jcr:description="Assigns the article to a reviewer from the reviewers group"
                jcr:title="Review Article"
                sling:resourceType="cq/workflow/components/model/dynamicparticipant"
                DYNAMIC_PARTICIPANT="com.mysite.core.workflow.AssignReviewerStep"
                type="DYNAMIC_PARTICIPANT">
                <transitions jcr:primaryType="nt:unstructured">
                    <node2_x0023_node3
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="cq/workflow/components/model/transition"
                        to="node3"/>
                </transitions>
            </node2>
            <node3
                jcr:primaryType="nt:unstructured"
                jcr:description="Reviewer decides whether to approve or reject"
                jcr:title="Approve or Reject"
                sling:resourceType="cq/workflow/components/model/orsplit"
                type="OR_SPLIT">
                <transitions jcr:primaryType="nt:unstructured">
                    <node3_x0023_node4
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Approve"
                        sling:resourceType="cq/workflow/components/model/transition"
                        to="node4"/>
                    <node3_x0023_node5
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Reject"
                        sling:resourceType="cq/workflow/components/model/transition"
                        to="node5"/>
                </transitions>
            </node3>
            <node4
                jcr:primaryType="nt:unstructured"
                jcr:description="Sets article status to approved with approval metadata"
                jcr:title="Approve Article"
                sling:resourceType="cq/workflow/components/model/process"
                PROCESS="com.mysite.core.workflow.ApproveArticleStep"
                PROCESS_AUTO_ADVANCE="{Boolean}true"
                type="PROCESS">
                <transitions jcr:primaryType="nt:unstructured">
                    <node4_x0023_node6
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="cq/workflow/components/model/transition"
                        to="node6"/>
                </transitions>
            </node4>
            <node5
                jcr:primaryType="nt:unstructured"
                jcr:description="Sets article status to rejected with rejection reason"
                jcr:title="Reject Article"
                sling:resourceType="cq/workflow/components/model/process"
                PROCESS="com.mysite.core.workflow.RejectArticleStep"
                PROCESS_AUTO_ADVANCE="{Boolean}true"
                type="PROCESS">
                <transitions jcr:primaryType="nt:unstructured">
                    <node5_x0023_node6
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="cq/workflow/components/model/transition"
                        to="node6"/>
                </transitions>
            </node5>
            <node6
                jcr:primaryType="nt:unstructured"
                jcr:title="End"
                sling:resourceType="cq/workflow/components/model/end"
                type="END"/>
        </flow>
    </jcr:content>
</jcr:root>
